<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form">
  <f:section title="${%GSD / AI pull request reviewer}">
    <f:entry title="${%Default Anthropic model}" field="defaultAnthropicModel">
      <f:textbox/>
    </f:entry>
    <f:entry title="${%Anthropic API base URL}" field="anthropicBaseUrl">
      <f:textbox/>
    </f:entry>
    <f:entry title="${%Default max diff lines}" field="defaultMaxDiffLines">
      <f:number clazz="positive-number-required" min="1" default="500"/>
    </f:entry>
    <f:entry title="${%Default GitHub API URL}" field="defaultGithubApiUrl">
      <f:textbox placeholder="https://api.github.com"/>
    </f:entry>
  </f:section>
</j:jelly>
